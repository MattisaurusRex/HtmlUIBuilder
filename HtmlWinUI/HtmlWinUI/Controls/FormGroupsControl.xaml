<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="HtmlWinUI.Controls.FormGroupsControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:HtmlWinUI.Controls"
    xmlns:vm="using:HtmlWinUI.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!-- One action button (colour/icon/tooltip from the model's Button metadata). -->
        <DataTemplate x:Key="ActionButtonTemplate" x:DataType="vm:ButtonSpec">
            <Button Background="{x:Bind Background}"
                    Foreground="{x:Bind Foreground}"
                    ToolTipService.ToolTip="{x:Bind Tooltip}"
                    CornerRadius="6"
                    Padding="10,6"
                    Margin="0,0,8,8"
                    FontSize="12"
                    FontWeight="SemiBold"
                    HorizontalAlignment="Stretch">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Image Source="{x:Bind Icon}" Width="16" Height="16" Visibility="{x:Bind HasIcon}" />
                    <TextBlock Text="{x:Bind Text}" Visibility="{x:Bind HasText}" />
                </StackPanel>
            </Button>
        </DataTemplate>

        <DataTemplate x:Key="TextFieldTemplate" x:DataType="vm:TextFormField">
            <Grid ColumnSpacing="8" Margin="0,0,12,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Header="{x:Bind Label}" Text="{x:Bind Text, Mode=TwoWay}" />
                <ItemsControl Grid.Column="1"
                              VerticalAlignment="Bottom"
                              ItemsSource="{x:Bind InlineButtons}"
                              ItemTemplate="{StaticResource ActionButtonTemplate}"
                              Visibility="{x:Bind HasInlineButtons}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="BoolFieldTemplate" x:DataType="vm:BoolFormField">
            <CheckBox Content="{x:Bind Label}"
                      IsChecked="{x:Bind Value, Mode=TwoWay}"
                      VerticalAlignment="Bottom"
                      Margin="0,0,12,8" />
        </DataTemplate>

        <DataTemplate x:Key="DateFieldTemplate" x:DataType="vm:DateFormField">
            <CalendarDatePicker Header="{x:Bind Label}"
                                Date="{x:Bind Date, Mode=TwoWay}"
                                HorizontalAlignment="Stretch"
                                Margin="0,0,12,8" />
        </DataTemplate>

        <DataTemplate x:Key="SelectFieldTemplate" x:DataType="vm:SelectFormField">
            <Grid ColumnSpacing="8" Margin="0,0,12,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ComboBox Header="{x:Bind Label}"
                          ItemsSource="{x:Bind Options}"
                          SelectedItem="{x:Bind Selected, Mode=TwoWay}"
                          PlaceholderText="{x:Bind Placeholder}"
                          HorizontalAlignment="Stretch" />
                <ItemsControl Grid.Column="1"
                              VerticalAlignment="Bottom"
                              ItemsSource="{x:Bind InlineButtons}"
                              ItemTemplate="{StaticResource ActionButtonTemplate}"
                              Visibility="{x:Bind HasInlineButtons}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </Grid>
        </DataTemplate>

        <local:FormFieldTemplateSelector x:Key="FormFieldSelector"
                                         TextTemplate="{StaticResource TextFieldTemplate}"
                                         BoolTemplate="{StaticResource BoolFieldTemplate}"
                                         DateTemplate="{StaticResource DateFieldTemplate}"
                                         ComboTemplate="{StaticResource SelectFieldTemplate}" />

        <!-- A run of input fields, wrapping into columns on wide windows. -->
        <DataTemplate x:Key="InputBlockTemplate" x:DataType="vm:InputFieldsBlock">
            <ItemsRepeater ItemsSource="{x:Bind Fields}" ItemTemplate="{StaticResource FormFieldSelector}">
                <ItemsRepeater.Layout>
                    <UniformGridLayout MinItemWidth="300"
                                       MinItemHeight="72"
                                       MinColumnSpacing="4"
                                       MinRowSpacing="2"
                                       ItemsStretch="Fill" />
                </ItemsRepeater.Layout>
            </ItemsRepeater>
        </DataTemplate>

        <DataTemplate x:Key="ButtonRowBlockTemplate" x:DataType="vm:ButtonRowBlock">
            <ItemsRepeater ItemsSource="{x:Bind Buttons}" ItemTemplate="{StaticResource ActionButtonTemplate}" Margin="0,4,0,4">
                <ItemsRepeater.Layout>
                    <UniformGridLayout MinItemWidth="170" ItemsStretch="Fill" />
                </ItemsRepeater.Layout>
            </ItemsRepeater>
        </DataTemplate>

        <DataTemplate x:Key="TableBlockTemplate" x:DataType="vm:TableBlock">
            <StackPanel Margin="0,4,0,10">
                <TextBlock Text="{x:Bind Label}"
                           Visibility="{x:Bind HasLabel}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4" />
                <local:SimpleTable Table="{x:Bind Table}" />
            </StackPanel>
        </DataTemplate>

        <local:FormBlockTemplateSelector x:Key="FormBlockSelector"
                                         InputBlockTemplate="{StaticResource InputBlockTemplate}"
                                         ButtonRowBlockTemplate="{StaticResource ButtonRowBlockTemplate}"
                                         TableBlockTemplate="{StaticResource TableBlockTemplate}" />
    </UserControl.Resources>

    <ItemsControl x:Name="GroupsHost">
        <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:FormGroup">
                <StackPanel Margin="0,0,0,12">
                    <Border Visibility="{x:Bind HasHeading}"
                            BorderBrush="{StaticResource GroupHeadingBorderBrush}"
                            BorderThickness="1"
                            Padding="8,2">
                        <TextBlock Text="{x:Bind Heading}"
                                   Foreground="{StaticResource GroupHeadingBrush}"
                                   FontSize="12" />
                    </Border>
                    <Border BorderBrush="{StaticResource GroupBorderBrush}"
                            BorderThickness="1"
                            Padding="10"
                            CornerRadius="2">
                        <ItemsControl ItemsSource="{x:Bind Blocks}" ItemTemplateSelector="{StaticResource FormBlockSelector}" />
                    </Border>
                </StackPanel>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>
