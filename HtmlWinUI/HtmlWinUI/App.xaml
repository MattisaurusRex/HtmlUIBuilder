<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="HtmlWinUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:HtmlWinUI"
    RequestedTheme="Light">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Palette ported from HtmlUI/wwwroot/css/site.css -->
            <SolidColorBrush x:Key="NavBarBrush" Color="#5791EB" />
            <SolidColorBrush x:Key="SubmitButtonBrush" Color="#5783DB" />
            <SolidColorBrush x:Key="GroupBorderBrush" Color="#D3D3E0" />
            <SolidColorBrush x:Key="GroupHeadingBorderBrush" Color="#E9E9EF" />
            <SolidColorBrush x:Key="GroupHeadingBrush" Color="Navy" />
            <SolidColorBrush x:Key="CustomBlackBrush" Color="#575756" />
            <LinearGradientBrush x:Key="NavButtonBrush" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#75B9FF" Offset="0" />
                <GradientStop Color="#5791EB" Offset="1" />
            </LinearGradientBrush>

            <Style x:Key="PageTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="24" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{StaticResource CustomBlackBrush}" />
                <Setter Property="Margin" Value="0,0,0,16" />
            </Style>

            <Style x:Key="NavButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource NavButtonBrush}" />
                <Setter Property="Foreground" Value="Navy" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Padding" Value="14,6" />
                <Setter Property="BorderThickness" Value="0" />
            </Style>

            <Style x:Key="SubmitButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource SubmitButtonBrush}" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Padding" Value="24,8" />
            </Style>

            <Style x:Key="DashboardButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="White" />
                <Setter Property="BorderBrush" Value="{StaticResource GroupBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="6" />
                <Setter Property="Padding" Value="24,16" />
                <Setter Property="MinWidth" Value="420" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
