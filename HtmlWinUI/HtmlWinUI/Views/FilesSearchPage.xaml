<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HtmlWinUI.Views.FilesSearchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!-- Fixed 1908px design width (6 field columns per group); the Viewbox scales
         the whole form up or down so it always fits one screen without scrolling. -->
    <Viewbox Stretch="Uniform" Margin="12">
        <StackPanel Padding="24" Width="1908">
            <TextBlock Text="Files Search" Style="{StaticResource PageTitleStyle}" />

            <!-- Client -->
            <StackPanel Margin="0,0,0,12">
                <Border Style="{StaticResource GroupHeadingBorderStyle}">
                    <TextBlock Text="Client" Style="{StaticResource GroupHeadingTextStyle}" />
                </Border>
                <Border Style="{StaticResource GroupBodyStyle}">
                    <VariableSizedWrapGrid Orientation="Horizontal" ItemWidth="304" ItemHeight="76">
                        <TextBox Header="ID" Text="{x:Bind Model.ID, Mode=TwoWay}" Style="{StaticResource FieldTextBoxStyle}" />
                        <TextBox Header="Barcode" Text="{x:Bind Model.Barcode, Mode=TwoWay}" Style="{StaticResource FieldTextBoxStyle}" />
                        <TextBox Header="Client" Text="{x:Bind Model.Client, Mode=TwoWay}" Style="{StaticResource FieldTextBoxStyle}" />
                        <TextBox Header="Section Number" Text="{x:Bind Model.SectionNo, Mode=TwoWay}" Style="{StaticResource FieldTextBoxStyle}" />
                        <TextBox Header="Section Status" Text="{x:Bind Model.SectionStatus, Mode=TwoWay}" Style="{StaticResource FieldTextBoxStyle}" />
                        <TextBox Header="Issue Number" Text="{x:Bind Model.IssueNo, Mode=TwoWay}" Style="{StaticResource FieldTextBoxStyle}" />
                        <TextBox Header="Case Reference" Text="{x:Bind Model.CaseRef, Mode=TwoWay}" Style="{StaticResource FieldTextBoxStyle}" />
                        <ComboBox Header="Client Status" ItemsSource="{x:Bind Model.ClientStatus}" PlaceholderText="Select a Client Status" Style="{StaticResource FieldComboBoxStyle}" />
                        <TextBox Header="File Result" Text="{x:Bind Model.FileResult, Mode=TwoWay}" Style="{StaticResource FieldTextBoxStyle}" />
                        <TextBox Header="Business Class" Text="{x:Bind Model.BusinessClass, Mode=TwoWay}" Style="{StaticResource FieldTextBoxStyle}" />
                        <TextBox Header="Territory" Text="{x:Bind Model.Territory, Mode=TwoWay}" Style="{StaticResource FieldTextBoxStyle}" />
                        <TextBox Header="Invoice ID" Text="{x:Bind Model.InvoiceID, Mode=TwoWay}" Style="{StaticResource FieldTextBoxStyle}" />
                        <CheckBox Content="Without Invoice" IsChecked="{x:Bind Model.WithoutInvoice, Mode=TwoWay}" Style="{StaticResource FieldCheckBoxStyle}" />
                    </VariableSizedWrapGrid>
                </Border>
            </StackPanel>

            <!-- Dates -->
            <StackPanel Margin="0,0,0,12">
                <Border Style="{StaticResource GroupHeadingBorderStyle}">
                    <TextBlock Text="Dates" Style="{StaticResource GroupHeadingTextStyle}" />
                </Border>
                <Border Style="{StaticResource GroupBodyStyle}">
                    <VariableSizedWrapGrid Orientation="Horizontal" ItemWidth="304" ItemHeight="76">
                        <CalendarDatePicker Header="File From" Date="{x:Bind Model.FileFrom, Converter={StaticResource DateConverter}, Mode=TwoWay}" Style="{StaticResource FieldDatePickerStyle}" />
                        <CalendarDatePicker Header="File To" Date="{x:Bind Model.FileTo, Converter={StaticResource DateConverter}, Mode=TwoWay}" Style="{StaticResource FieldDatePickerStyle}" />
                        <CalendarDatePicker Header="Received From" Date="{x:Bind Model.ReceivedFrom, Converter={StaticResource DateConverter}, Mode=TwoWay}" Style="{StaticResource FieldDatePickerStyle}" />
                        <CalendarDatePicker Header="Received To" Date="{x:Bind Model.ReceivedTo, Converter={StaticResource DateConverter}, Mode=TwoWay}" Style="{StaticResource FieldDatePickerStyle}" />
                        <CalendarDatePicker Header="Released From" Date="{x:Bind Model.ReleasedFrom, Converter={StaticResource DateConverter}, Mode=TwoWay}" Style="{StaticResource FieldDatePickerStyle}" />
                        <CalendarDatePicker Header="Released To" Date="{x:Bind Model.ReleasedTo, Converter={StaticResource DateConverter}, Mode=TwoWay}" Style="{StaticResource FieldDatePickerStyle}" />
                        <CalendarDatePicker Header="Approved From" Date="{x:Bind Model.ApprovedFrom, Converter={StaticResource DateConverter}, Mode=TwoWay}" Style="{StaticResource FieldDatePickerStyle}" />
                        <CalendarDatePicker Header="Approved To" Date="{x:Bind Model.ApprovedTo, Converter={StaticResource DateConverter}, Mode=TwoWay}" Style="{StaticResource FieldDatePickerStyle}" />
                        <CalendarDatePicker Header="Reported From" Date="{x:Bind Model.ReportedFrom, Converter={StaticResource DateConverter}, Mode=TwoWay}" Style="{StaticResource FieldDatePickerStyle}" />
                        <CalendarDatePicker Header="Reported To" Date="{x:Bind Model.ReportedTo, Converter={StaticResource DateConverter}, Mode=TwoWay}" Style="{StaticResource FieldDatePickerStyle}" />
                        <CalendarDatePicker Header="Invoiced From" Date="{x:Bind Model.InvoicedFrom, Converter={StaticResource DateConverter}, Mode=TwoWay}" Style="{StaticResource FieldDatePickerStyle}" />
                        <CalendarDatePicker Header="Invoiced To" Date="{x:Bind Model.InvoicedTo, Converter={StaticResource DateConverter}, Mode=TwoWay}" Style="{StaticResource FieldDatePickerStyle}" />
                    </VariableSizedWrapGrid>
                </Border>
            </StackPanel>

            <!-- Patient -->
            <StackPanel Margin="0,0,0,12">
                <Border Style="{StaticResource GroupHeadingBorderStyle}">
                    <TextBlock Text="Patient" Style="{StaticResource GroupHeadingTextStyle}" />
                </Border>
                <Border Style="{StaticResource GroupBodyStyle}">
                    <VariableSizedWrapGrid Orientation="Horizontal" ItemWidth="304" ItemHeight="76">
                        <TextBox Header="Patient Forename" Text="{x:Bind Model.PatientForename, Mode=TwoWay}" Style="{StaticResource FieldTextBoxStyle}" />
                        <TextBox Header="Patient Surname" Text="{x:Bind Model.PatientSurname, Mode=TwoWay}" Style="{StaticResource FieldTextBoxStyle}" />
                        <TextBox Header="Patient Gender" Text="{x:Bind Model.PatientGender, Mode=TwoWay}" Style="{StaticResource FieldTextBoxStyle}" />
                        <CalendarDatePicker Header="Patient DOB" Date="{x:Bind Model.PatientDOB, Converter={StaticResource DateConverter}, Mode=TwoWay}" Style="{StaticResource FieldDatePickerStyle}" />
                        <TextBox Header="Patient NI Number" Text="{x:Bind Model.PatientNINumber, Mode=TwoWay}" Style="{StaticResource FieldTextBoxStyle}" />
                        <TextBox Header="Patient Passport Number" Text="{x:Bind Model.PatientPassportNumber, Mode=TwoWay}" Style="{StaticResource FieldTextBoxStyle}" />
                    </VariableSizedWrapGrid>
                </Border>
            </StackPanel>

            <!-- Office -->
            <StackPanel Margin="0,0,0,12">
                <Border Style="{StaticResource GroupHeadingBorderStyle}">
                    <TextBlock Text="Office" Style="{StaticResource GroupHeadingTextStyle}" />
                </Border>
                <Border Style="{StaticResource GroupBodyStyle}">
                    <VariableSizedWrapGrid Orientation="Horizontal" ItemWidth="304" ItemHeight="76">
                        <TextBox Header="File Type" Text="{x:Bind Model.FileType, Mode=TwoWay}" Style="{StaticResource FieldTextBoxStyle}" />
                        <TextBox Header="Collector" Text="{x:Bind Model.Collector, Mode=TwoWay}" Style="{StaticResource FieldTextBoxStyle}" />
                        <TextBox Header="Test Purpose" Text="{x:Bind Model.TestPurpose, Mode=TwoWay}" Style="{StaticResource FieldTextBoxStyle}" />
                        <TextBox Header="File Colour" Text="{x:Bind Model.FileColour, Mode=TwoWay}" Style="{StaticResource FieldTextBoxStyle}" />
                        <TextBox Header="Documentation" Text="{x:Bind Model.Documentation, Mode=TwoWay}" Style="{StaticResource FieldTextBoxStyle}" />
                        <TextBox Header="Identification" Text="{x:Bind Model.Identification, Mode=TwoWay}" Style="{StaticResource FieldTextBoxStyle}" />
                        <TextBox Header="Collection Status" Text="{x:Bind Model.CollectionStatus, Mode=TwoWay}" Style="{StaticResource FieldTextBoxStyle}" />
                        <CheckBox Content="Print" IsChecked="{x:Bind Model.Print, Mode=TwoWay}" Style="{StaticResource FieldCheckBoxStyle}" />
                        <TextBox Header="Workflow" Text="{x:Bind Model.Workflow, Mode=TwoWay}" Style="{StaticResource FieldTextBoxStyle}" />
                        <TextBox Header="SBC" Text="{x:Bind Model.SBC, Mode=TwoWay}" Style="{StaticResource FieldTextBoxStyle}" />
                        <TextBox Header="ID Type" Text="{x:Bind Model.IDType, Mode=TwoWay}" Style="{StaticResource FieldTextBoxStyle}" />
                    </VariableSizedWrapGrid>
                </Border>
            </StackPanel>

            <Button Content="Submit"
                    Click="Submit_Click"
                    Style="{StaticResource SubmitButtonStyle}"
                    HorizontalAlignment="Center"
                    Margin="0,8,0,0" />
        </StackPanel>
    </Viewbox>
</Page>
