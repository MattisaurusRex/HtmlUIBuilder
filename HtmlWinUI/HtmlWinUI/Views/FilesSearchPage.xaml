<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HtmlWinUI.Views.FilesSearchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:HtmlWinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="24" MaxWidth="1200">
            <TextBlock Text="Files Search" Style="{StaticResource PageTitleStyle}" />
            <controls:FormGroupsControl x:Name="SearchGroups" />
            <Button Content="Submit"
                    Click="Submit_Click"
                    Style="{StaticResource SubmitButtonStyle}"
                    HorizontalAlignment="Center"
                    Margin="0,8,0,24" />
        </StackPanel>
    </ScrollViewer>
</Page>
