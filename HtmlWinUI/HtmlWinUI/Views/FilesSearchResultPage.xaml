<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HtmlWinUI.Views.FilesSearchResultPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:HtmlWinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="24">
            <TextBlock Text="File Search Results" Style="{StaticResource PageTitleStyle}" />
            <controls:SimpleTable x:Name="ResultsTable" HorizontalAlignment="Left" />
        </StackPanel>
    </ScrollViewer>
</Page>
