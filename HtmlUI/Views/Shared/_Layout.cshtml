@using HtmlUI.Helpers
@{
    var navbarBtns = new List<string> { "Files", "Customers", "Quotes", "Invoices" };
    var ver = new List<string> { "Version 1.2", "Connected: Live" };
    var config = "live";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HtmlUI</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/HtmlUI.styles.css" asp-append-version="true" />
    <link href="~/DataTables/datatables.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />    
</head>
<body>
    <header>                
        @* <nav class="navbar navbar-expand-sm navbar-toggleable-sm border-bottom box-shadow navBar"> *@
            @Html.NavbarHeader(config)
            <div class="container-fluid">
                <a class="navbar-brand" id="headerTextHome" asp-area="" asp-controller="Home" asp-action="Index">HtmlUI</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                @Html.NavbarButtons(navbarBtns , config) 
                @Html.NavbarVersionInfo(ver)
            </div>
        </nav>
    </header>
    <div class="container mainWindow">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    @* <footer class="navBarFooter text-muted"> *@
    @Html.NavbarFooter(config)
        <div class="container footerText">
            <div id="footerAboutTag"> &copy; 2025 - <a asp-area="" asp-controller="Home" asp-action="About">About</a></div>
            <p id="userNameFooter">[User One]</p>
        </div>
    </footer>
    <script src="https://kit.fontawesome.com/2894ed453d.js" crossorigin="anonymous"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>    
    <script src="~/DataTables/datatables.min.js"></script>
    <script language="JavaScript">

        $(document).on("keydown", function (e) {
            // use e.which
            alert(e.which);
        });

    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
