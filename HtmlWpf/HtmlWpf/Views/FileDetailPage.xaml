<Page
    x:Class="HtmlWpf.Views.FileDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:HtmlWpf.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="File Detail">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header panel (FileDetailHeader.HeaderView): fixed 1908px design width in
             7 columns, scaled by the Viewbox to the window width, never above 500px tall. -->
        <Viewbox Grid.Row="0" Stretch="Uniform" MaxHeight="500" Margin="0,0,0,12">
            <StackPanel x:Name="FileHeaderView" Width="1908">
                <Border Style="{StaticResource GroupBodyStyle}">
                    <WrapPanel Orientation="Horizontal" ItemHeight="76">
                        <HeaderedContentControl Header="ID#" Style="{StaticResource FieldStyle266}">
                            <TextBox Text="{Binding EntityIdText, Mode=OneWay}" />
                        </HeaderedContentControl>
                        <HeaderedContentControl Header="File Barcode" Style="{StaticResource FieldStyle266}">
                            <TextBox Text="{Binding Detail.FileBarcode, Mode=TwoWay}" />
                        </HeaderedContentControl>
                        <Button Content="Related Files" ToolTip="Related Files" Width="258" VerticalAlignment="Bottom" Style="{StaticResource BlueActionButtonStyle}" />
                        <Button Content="View Quote" ToolTip="View Quote" Width="258" VerticalAlignment="Bottom" Style="{StaticResource BlueActionButtonStyle}" />
                        <HeaderedContentControl Header="Case Reference" Style="{StaticResource FieldStyle266}">
                            <TextBox Text="{Binding Detail.CaseReference, Mode=TwoWay}" />
                        </HeaderedContentControl>
                        <HeaderedContentControl Header="Split" Style="{StaticResource FieldStyle266}">
                            <controls:PlaceholderComboBox ItemsSource="{Binding Detail.Split}" PlaceholderText="Select a Split" />
                        </HeaderedContentControl>
                        <HeaderedContentControl Header="File Status" Style="{StaticResource FieldStyle266}">
                            <controls:PlaceholderComboBox ItemsSource="{Binding Detail.FileStatus}" PlaceholderText="Select a File Status" />
                        </HeaderedContentControl>
                        <Button ToolTip="File Folder" Width="258" VerticalAlignment="Bottom" Style="{StaticResource BlueActionButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Assets/Images/folder.png" Width="16" Height="16" Margin="0,0,6,0" />
                                <TextBlock Text="File Folder" />
                            </StackPanel>
                        </Button>
                        <!-- Spans two 266px cells (WinUI VariableSizedWrapGrid.ColumnSpan=2) -->
                        <Grid Width="520" Margin="0,0,12,8" VerticalAlignment="Bottom">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <HeaderedContentControl Header="File Segments" Style="{StaticResource FieldStyle}" Padding="0">
                                <TextBox Text="{Binding Detail.FileSegments, Mode=TwoWay}" />
                            </HeaderedContentControl>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="8,0,0,0">
                                <Button Content="Pick Segments" ToolTip="Pick Segments" Style="{StaticResource OrangeActionButtonStyle}" />
                            </StackPanel>
                        </Grid>
                    </WrapPanel>
                </Border>
            </StackPanel>
        </Viewbox>

        <!-- Tabbed detail area, one TabItem per DetailTabItem -->
        <TabControl x:Name="DetailTabs" Grid.Row="1" Margin="0,4,0,0">

            <!-- Customer -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Assets/Images/customer.png" Width="16" Height="16" Margin="0,0,6,0" />
                        <TextBlock Text="Customer" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <StackPanel Margin="0,0,0,12">
                            <Border Style="{StaticResource GroupBodyStyle}">
                                <StackPanel>
                                    <WrapPanel Orientation="Horizontal" ItemWidth="304" ItemHeight="76">
                                        <Grid Margin="0,0,12,8" VerticalAlignment="Bottom">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <HeaderedContentControl Header="Job Number" Style="{StaticResource FieldStyle}" Padding="0">
                                                <TextBox Text="{Binding CustomerTab.JobNo, Mode=TwoWay}" />
                                            </HeaderedContentControl>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="8,0,0,0">
                                                <Button ToolTip="Assign To Job" Style="{StaticResource PurpleActionButtonStyle}">
                                                    <Image Source="/Assets/Images/binoculars.png" Width="16" Height="16" />
                                                </Button>
                                                <Button ToolTip="Create Job" Style="{StaticResource PurpleActionButtonStyle}">
                                                    <Image Source="/Assets/Images/plus-one.png" Width="16" Height="16" />
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                        <HeaderedContentControl Header="Job Date" Style="{StaticResource FieldStyle}">
                                            <DatePicker SelectedDate="{Binding CustomerTab.JobDate, Converter={StaticResource DateConverter}, Mode=TwoWay}" />
                                        </HeaderedContentControl>
                                    </WrapPanel>
                                    <StackPanel Margin="0,4,0,10">
                                        <TextBlock Text="Customer" Style="{StaticResource TableLabelStyle}" />
                                        <controls:EntityTable ItemsSource="{Binding CustomerTab.Customer}" />
                                    </StackPanel>
                                    <WrapPanel Orientation="Horizontal" ItemWidth="304" ItemHeight="76">
                                        <HeaderedContentControl Header="Delivery Method" Style="{StaticResource FieldStyle}">
                                            <controls:PlaceholderComboBox ItemsSource="{Binding CustomerTab.DeliveryMethod}" PlaceholderText="Select a Delivery Method" />
                                        </HeaderedContentControl>
                                        <CheckBox Content="Report As Job" IsChecked="{Binding CustomerTab.ReportAsJob, Mode=TwoWay}" Style="{StaticResource FieldCheckBoxStyle}" />
                                        <HeaderedContentControl Header="Delivery Destination" Style="{StaticResource FieldStyle}">
                                            <TextBox Text="{Binding CustomerTab.DeliveryDestination, Mode=TwoWay}" />
                                        </HeaderedContentControl>
                                        <HeaderedContentControl Header="Quote ID" Style="{StaticResource FieldStyle}">
                                            <TextBox Text="{Binding CustomerTab.QuoteID, Mode=TwoWay}" />
                                        </HeaderedContentControl>
                                    </WrapPanel>
                                    <WrapPanel Orientation="Horizontal" ItemWidth="178" Margin="0,4,0,4">
                                        <Button ToolTip="Follow Up Email" Style="{StaticResource WhiteActionButtonStyle}">
                                            <StackPanel Orientation="Horizontal">
                                                <Image Source="/Assets/Images/email.png" Width="16" Height="16" Margin="0,0,6,0" />
                                                <TextBlock Text="Follow Up Email" />
                                            </StackPanel>
                                        </Button>
                                    </WrapPanel>
                                    <WrapPanel Orientation="Horizontal" ItemWidth="304" ItemHeight="76">
                                        <CheckBox Content="Follow Up Sent" IsChecked="{Binding CustomerTab.FollowUpSent, Mode=TwoWay}" Style="{StaticResource FieldCheckBoxStyle}" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <Button Content="Submit" Style="{StaticResource SubmitButtonStyle}" HorizontalAlignment="Left" Margin="0,4,0,12" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Properties -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Assets/Images/folder.png" Width="16" Height="16" Margin="0,0,6,0" />
                        <TextBlock Text="Properties" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <StackPanel Margin="0,0,0,12">
                            <Border Style="{StaticResource GroupHeadingBorderStyle}">
                                <TextBlock Text="Collection" Style="{StaticResource GroupHeadingTextStyle}" />
                            </Border>
                            <Border Style="{StaticResource GroupBodyStyle}">
                                <WrapPanel Orientation="Horizontal" ItemWidth="304" ItemHeight="76">
                                    <HeaderedContentControl Header="Date Of Collection" Style="{StaticResource FieldStyle}">
                                        <DatePicker SelectedDate="{Binding PropertiesTab.DateOfCollection, Converter={StaticResource DateConverter}, Mode=TwoWay}" />
                                    </HeaderedContentControl>
                                    <HeaderedContentControl Header="Collector" Style="{StaticResource FieldStyle}">
                                        <controls:PlaceholderComboBox ItemsSource="{Binding PropertiesTab.Collector}" PlaceholderText="Select a Collector" />
                                    </HeaderedContentControl>
                                    <CheckBox Content="Collected By Us" IsChecked="{Binding PropertiesTab.CollectedByUs, Mode=TwoWay}" Style="{StaticResource FieldCheckBoxStyle}" />
                                </WrapPanel>
                            </Border>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,12">
                            <Border Style="{StaticResource GroupHeadingBorderStyle}">
                                <TextBlock Text="Reporting Methods" Style="{StaticResource GroupHeadingTextStyle}" />
                            </Border>
                            <Border Style="{StaticResource GroupBodyStyle}">
                                <StackPanel Margin="0,4,0,10">
                                    <TextBlock Text="Reporting Methods" Style="{StaticResource TableLabelStyle}" />
                                    <controls:EntityTable ItemsSource="{Binding PropertiesTab.ReportingMethods}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,12">
                            <Border Style="{StaticResource GroupHeadingBorderStyle}">
                                <TextBlock Text="Treatments" Style="{StaticResource GroupHeadingTextStyle}" />
                            </Border>
                            <Border Style="{StaticResource GroupBodyStyle}">
                                <StackPanel Margin="0,4,0,10">
                                    <TextBlock Text="Treatments" Style="{StaticResource TableLabelStyle}" />
                                    <controls:EntityTable ItemsSource="{Binding PropertiesTab.Treatments}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,12">
                            <Border Style="{StaticResource GroupHeadingBorderStyle}">
                                <TextBlock Text="Checks" Style="{StaticResource GroupHeadingTextStyle}" />
                            </Border>
                            <Border Style="{StaticResource GroupBodyStyle}">
                                <WrapPanel Orientation="Horizontal" ItemWidth="304" ItemHeight="76">
                                    <CheckBox Content="Signed By Collector" IsChecked="{Binding PropertiesTab.SignedByCollector, Mode=TwoWay}" Style="{StaticResource FieldCheckBoxStyle}" />
                                    <CheckBox Content="Signed By Patient" IsChecked="{Binding PropertiesTab.SignedByPatient, Mode=TwoWay}" Style="{StaticResource FieldCheckBoxStyle}" />
                                    <CheckBox Content="Seal Intact" IsChecked="{Binding PropertiesTab.SealIntact, Mode=TwoWay}" Style="{StaticResource FieldCheckBoxStyle}" />
                                </WrapPanel>
                            </Border>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,12">
                            <Border Style="{StaticResource GroupHeadingBorderStyle}">
                                <TextBlock Text="File Type" Style="{StaticResource GroupHeadingTextStyle}" />
                            </Border>
                            <Border Style="{StaticResource GroupBodyStyle}">
                                <WrapPanel Orientation="Horizontal" ItemWidth="304" ItemHeight="76">
                                    <HeaderedContentControl Header="Identification" Style="{StaticResource FieldStyle}">
                                        <controls:PlaceholderComboBox ItemsSource="{Binding PropertiesTab.Identification}" PlaceholderText="Select a Identification" />
                                    </HeaderedContentControl>
                                    <HeaderedContentControl Header="ID Type" Style="{StaticResource FieldStyle}">
                                        <controls:PlaceholderComboBox ItemsSource="{Binding PropertiesTab.IDType}" PlaceholderText="Select a ID Type" />
                                    </HeaderedContentControl>
                                    <HeaderedContentControl Header="Effective Type" Style="{StaticResource FieldStyle}">
                                        <controls:PlaceholderComboBox ItemsSource="{Binding PropertiesTab.EffectiveType}" PlaceholderText="Select a Effective Type" />
                                    </HeaderedContentControl>
                                    <HeaderedContentControl Header="Folder Colour" Style="{StaticResource FieldStyle}">
                                        <controls:PlaceholderComboBox ItemsSource="{Binding PropertiesTab.FolderColour}" PlaceholderText="Select a Folder Colour" />
                                    </HeaderedContentControl>
                                    <HeaderedContentControl Header="Document Type" Style="{StaticResource FieldStyle}">
                                        <controls:PlaceholderComboBox ItemsSource="{Binding PropertiesTab.DocumentType}" PlaceholderText="Select a Document Type" />
                                    </HeaderedContentControl>
                                    <HeaderedContentControl Header="AB File" Style="{StaticResource FieldStyle}">
                                        <controls:PlaceholderComboBox ItemsSource="{Binding PropertiesTab.ABFile}" PlaceholderText="Select a AB File" />
                                    </HeaderedContentControl>
                                </WrapPanel>
                            </Border>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,12">
                            <Border Style="{StaticResource GroupHeadingBorderStyle}">
                                <TextBlock Text="Other" Style="{StaticResource GroupHeadingTextStyle}" />
                            </Border>
                            <Border Style="{StaticResource GroupBodyStyle}">
                                <WrapPanel Orientation="Horizontal" ItemWidth="304" ItemHeight="76">
                                    <HeaderedContentControl Header="Received Date" Style="{StaticResource FieldStyle}">
                                        <DatePicker SelectedDate="{Binding PropertiesTab.ReceivedDate, Converter={StaticResource DateConverter}, Mode=TwoWay}" />
                                    </HeaderedContentControl>
                                    <HeaderedContentControl Header="Testing Purpose" Style="{StaticResource FieldStyle}">
                                        <controls:PlaceholderComboBox ItemsSource="{Binding PropertiesTab.TestingPurpose}" PlaceholderText="Select a Testing Purpose" />
                                    </HeaderedContentControl>
                                    <HeaderedContentControl Header="Received Pages" Style="{StaticResource FieldStyle}">
                                        <TextBox Text="{Binding ReceivedPagesText, Mode=OneWay}" />
                                    </HeaderedContentControl>
                                    <HeaderedContentControl Header="Destruction Due" Style="{StaticResource FieldStyle}">
                                        <TextBox Text="{Binding PropertiesTab.DestructionDue, Mode=TwoWay}" />
                                    </HeaderedContentControl>
                                    <HeaderedContentControl Header="Destroyed By" Style="{StaticResource FieldStyle}">
                                        <controls:PlaceholderComboBox ItemsSource="{Binding PropertiesTab.DestroyedBy}" PlaceholderText="Select a Destroyed By" />
                                    </HeaderedContentControl>
                                    <HeaderedContentControl Header="Destruction List ID" Style="{StaticResource FieldStyle}">
                                        <TextBox Text="{Binding PropertiesTab.DestructionListID, Mode=TwoWay}" />
                                    </HeaderedContentControl>
                                </WrapPanel>
                            </Border>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,12">
                            <Border Style="{StaticResource GroupHeadingBorderStyle}">
                                <TextBlock Text="Customer OS #" Style="{StaticResource GroupHeadingTextStyle}" />
                            </Border>
                            <Border Style="{StaticResource GroupBodyStyle}">
                                <WrapPanel Orientation="Horizontal" ItemWidth="304" ItemHeight="76">
                                    <HeaderedContentControl Header="Customer OS #" Style="{StaticResource FieldStyle}">
                                        <TextBox Text="{Binding PropertiesTab.CustomerOSNum, Mode=TwoWay}" />
                                    </HeaderedContentControl>
                                </WrapPanel>
                            </Border>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,12">
                            <Border Style="{StaticResource GroupHeadingBorderStyle}">
                                <TextBlock Text="Sub-Section" Style="{StaticResource GroupHeadingTextStyle}" />
                            </Border>
                            <Border Style="{StaticResource GroupBodyStyle}">
                                <WrapPanel Orientation="Horizontal" ItemWidth="304" ItemHeight="76">
                                    <HeaderedContentControl Header="Sub-Section" Style="{StaticResource FieldStyle}">
                                        <controls:PlaceholderComboBox ItemsSource="{Binding PropertiesTab.SubSection}" PlaceholderText="Select a Sub-Section" />
                                    </HeaderedContentControl>
                                </WrapPanel>
                            </Border>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,12">
                            <Border Style="{StaticResource GroupHeadingBorderStyle}">
                                <TextBlock Text="Identification Method" Style="{StaticResource GroupHeadingTextStyle}" />
                            </Border>
                            <Border Style="{StaticResource GroupBodyStyle}">
                                <WrapPanel Orientation="Horizontal" ItemWidth="304" ItemHeight="76">
                                    <HeaderedContentControl Header="Identification Method" Style="{StaticResource FieldStyle}">
                                        <controls:PlaceholderComboBox ItemsSource="{Binding PropertiesTab.IdentificationMethod}" PlaceholderText="Select a Identification Method" />
                                    </HeaderedContentControl>
                                </WrapPanel>
                            </Border>
                        </StackPanel>
                        <Button Content="Submit" Style="{StaticResource SubmitButtonStyle}" HorizontalAlignment="Left" Margin="0,4,0,12" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Patient -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Assets/Images/man.png" Width="16" Height="16" Margin="0,0,6,0" />
                        <TextBlock Text="Patient" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <StackPanel Margin="0,0,0,12">
                            <Border Style="{StaticResource GroupBodyStyle}">
                                <WrapPanel Orientation="Horizontal" ItemWidth="304" ItemHeight="76">
                                    <Grid Margin="0,0,12,8" VerticalAlignment="Bottom">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <HeaderedContentControl Header="PatientID" Style="{StaticResource FieldStyle}" Padding="0">
                                            <TextBox Text="{Binding PatientTab.PatientID, Mode=TwoWay}" />
                                        </HeaderedContentControl>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="8,0,0,0">
                                            <Button ToolTip="Search Patient" Style="{StaticResource PurpleActionButtonStyle}">
                                                <Image Source="/Assets/Images/telescope-look.png" Width="16" Height="16" />
                                            </Button>
                                            <Button ToolTip="Auto Select Anon" Style="{StaticResource PurpleActionButtonStyle}">
                                                <Image Source="/Assets/Images/smile.png" Width="16" Height="16" />
                                            </Button>
                                            <Button ToolTip="Use Barcode As Patient Name" Style="{StaticResource PurpleActionButtonStyle}">
                                                <Image Source="/Assets/Images/barcode-search.png" Width="16" Height="16" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                    <HeaderedContentControl Header="Forename" Style="{StaticResource FieldStyle}">
                                        <TextBox Text="{Binding PatientTab.Forename, Mode=TwoWay}" />
                                    </HeaderedContentControl>
                                    <HeaderedContentControl Header="Surname" Style="{StaticResource FieldStyle}">
                                        <TextBox Text="{Binding PatientTab.Surname, Mode=TwoWay}" />
                                    </HeaderedContentControl>
                                    <HeaderedContentControl Header="Gender" Style="{StaticResource FieldStyle}">
                                        <TextBox Text="{Binding PatientTab.Gender, Mode=TwoWay}" />
                                    </HeaderedContentControl>
                                    <HeaderedContentControl Header="DOB" Style="{StaticResource FieldStyle}">
                                        <DatePicker SelectedDate="{Binding PatientTab.DOB, Converter={StaticResource DateConverter}, Mode=TwoWay}" />
                                    </HeaderedContentControl>
                                    <HeaderedContentControl Header="NI" Style="{StaticResource FieldStyle}">
                                        <TextBox Text="{Binding PatientTab.NI, Mode=TwoWay}" />
                                    </HeaderedContentControl>
                                    <HeaderedContentControl Header="Passport" Style="{StaticResource FieldStyle}">
                                        <TextBox Text="{Binding PatientTab.Passport, Mode=TwoWay}" />
                                    </HeaderedContentControl>
                                    <HeaderedContentControl Header="Driving Licence" Style="{StaticResource FieldStyle}">
                                        <TextBox Text="{Binding PatientTab.DrivingLicence, Mode=TwoWay}" />
                                    </HeaderedContentControl>
                                    <HeaderedContentControl Header="ID4" Style="{StaticResource FieldStyle}">
                                        <TextBox Text="{Binding PatientTab.ID4, Mode=TwoWay}" />
                                    </HeaderedContentControl>
                                    <CheckBox Content="Difficult Patient" IsChecked="{Binding PatientTab.DifficultPatient, Mode=TwoWay}" Style="{StaticResource FieldCheckBoxStyle}" />
                                </WrapPanel>
                            </Border>
                        </StackPanel>
                        <Button Content="Submit" Style="{StaticResource SubmitButtonStyle}" HorizontalAlignment="Left" Margin="0,4,0,12" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Sections -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Assets/Images/ruler.png" Width="16" Height="16" Margin="0,0,6,0" />
                        <TextBlock Text="Sections" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <StackPanel Margin="0,0,0,12">
                            <Border Style="{StaticResource GroupHeadingBorderStyle}">
                                <TextBlock Text="Sections" Style="{StaticResource GroupHeadingTextStyle}" />
                            </Border>
                            <Border Style="{StaticResource GroupBodyStyle}">
                                <StackPanel>
                                    <StackPanel Margin="0,4,0,10">
                                        <TextBlock Text="Sections" Style="{StaticResource TableLabelStyle}" />
                                        <controls:EntityTable ItemsSource="{Binding SectionsTab.Sections}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,4,0,10">
                                        <TextBlock Text="Section Notes" Style="{StaticResource TableLabelStyle}" />
                                        <controls:EntityTable ItemsSource="{Binding SectionsTab.SectionNotes}" />
                                    </StackPanel>
                                    <WrapPanel Orientation="Horizontal" ItemWidth="178" Margin="0,4,0,4">
                                        <Button Content="Add" ToolTip="Add" Style="{StaticResource PurpleActionButtonStyle}" />
                                        <Button Content="Copy" ToolTip="Copy" Style="{StaticResource PurpleActionButtonStyle}" />
                                        <Button Content="Copy C of F" ToolTip="Copy C of F" Style="{StaticResource PurpleActionButtonStyle}" />
                                        <Button Content="Add Type" ToolTip="Add Type" Style="{StaticResource PurpleActionButtonStyle}" />
                                        <Button Content="Versions" ToolTip="Versions" Style="{StaticResource PurpleActionButtonStyle}" />
                                        <Button Content="Audit trail" ToolTip="Audit trail" Style="{StaticResource PurpleActionButtonStyle}" />
                                        <Button Content="Up-Issue" ToolTip="Up-Issue" Style="{StaticResource PurpleActionButtonStyle}" />
                                        <Button Content="Down-" ToolTip="Down-Issue" Style="{StaticResource PurpleActionButtonStyle}" />
                                    </WrapPanel>
                                    <WrapPanel Orientation="Horizontal" ItemWidth="304" ItemHeight="76">
                                        <Grid Margin="0,0,12,8" VerticalAlignment="Bottom">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <HeaderedContentControl Header="C of F Notes" Style="{StaticResource FieldStyle}" Padding="0">
                                                <controls:PlaceholderComboBox ItemsSource="{Binding SectionsTab.COfFNotes}" PlaceholderText="Select a C of F Notes" />
                                            </HeaderedContentControl>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="8,0,0,0">
                                                <Button ToolTip="Spell Check" Style="{StaticResource BlueActionButtonStyle}">
                                                    <Image Source="/Assets/Images/tick-abc.png" Width="16" Height="16" />
                                                </Button>
                                                <Button Content="Add Note" ToolTip="Add Note" Style="{StaticResource PurpleActionButtonStyle}" />
                                            </StackPanel>
                                        </Grid>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,12">
                            <Border Style="{StaticResource GroupHeadingBorderStyle}">
                                <TextBlock Text="Tests" Style="{StaticResource GroupHeadingTextStyle}" />
                            </Border>
                            <Border Style="{StaticResource GroupBodyStyle}">
                                <StackPanel>
                                    <StackPanel Margin="0,4,0,10">
                                        <TextBlock Text="Tests" Style="{StaticResource TableLabelStyle}" />
                                        <controls:EntityTable ItemsSource="{Binding SectionsTab.Tests}" />
                                    </StackPanel>
                                    <WrapPanel Orientation="Horizontal" ItemWidth="178" Margin="0,4,0,4">
                                        <Button Content="Add tests" ToolTip="Add Tests" Style="{StaticResource PurpleActionButtonStyle}" />
                                        <Button Content="Audit trail" ToolTip="Audit Trail" Style="{StaticResource PurpleActionButtonStyle}" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <Button Content="Submit" Style="{StaticResource SubmitButtonStyle}" HorizontalAlignment="Left" Margin="0,4,0,12" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Medications -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Assets/Images/drugs.png" Width="16" Height="16" Margin="0,0,6,0" />
                        <TextBlock Text="Medications" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <StackPanel Margin="0,0,0,12">
                            <Border Style="{StaticResource GroupBodyStyle}">
                                <WrapPanel Orientation="Horizontal" ItemWidth="178" Margin="0,4,0,4">
                                    <Button Content="Medication" ToolTip="Medication" Style="{StaticResource PurpleActionButtonStyle}" />
                                </WrapPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tools -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Assets/Images/tool-box.png" Width="16" Height="16" Margin="0,0,6,0" />
                        <TextBlock Text="Tools" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <StackPanel Margin="0,0,0,12">
                            <Border Style="{StaticResource GroupBodyStyle}">
                                <StackPanel>
                                    <WrapPanel Orientation="Horizontal" ItemWidth="178" Margin="0,4,0,4">
                                        <Button ToolTip="Release File" Style="{StaticResource PurpleActionButtonStyle}">
                                            <StackPanel Orientation="Horizontal">
                                                <Image Source="/Assets/Images/play.png" Width="16" Height="16" Margin="0,0,6,0" />
                                                <TextBlock Text="Release File" />
                                            </StackPanel>
                                        </Button>
                                        <Button ToolTip="Copy File" Style="{StaticResource PurpleActionButtonStyle}">
                                            <StackPanel Orientation="Horizontal">
                                                <Image Source="/Assets/Images/copy.png" Width="16" Height="16" Margin="0,0,6,0" />
                                                <TextBlock Text="Copy File" />
                                            </StackPanel>
                                        </Button>
                                        <Button ToolTip="Clone File" Style="{StaticResource PurpleActionButtonStyle}">
                                            <StackPanel Orientation="Horizontal">
                                                <Image Source="/Assets/Images/copy.png" Width="16" Height="16" Margin="0,0,6,0" />
                                                <TextBlock Text="Clone File" />
                                            </StackPanel>
                                        </Button>
                                    </WrapPanel>
                                    <WrapPanel Orientation="Horizontal" ItemWidth="178" Margin="0,4,0,4">
                                        <Button ToolTip="View Audit Trail" Style="{StaticResource PurpleActionButtonStyle}">
                                            <StackPanel Orientation="Horizontal">
                                                <Image Source="/Assets/Images/clipboard.png" Width="16" Height="16" Margin="0,0,6,0" />
                                                <TextBlock Text="View Audit Trail" />
                                            </StackPanel>
                                        </Button>
                                        <Button ToolTip="C of F Versions" Style="{StaticResource PurpleActionButtonStyle}">
                                            <StackPanel Orientation="Horizontal">
                                                <Image Source="/Assets/Images/version.png" Width="16" Height="16" Margin="0,0,6,0" />
                                                <TextBlock Text="C of F Versions" />
                                            </StackPanel>
                                        </Button>
                                        <Button ToolTip="File Actions Report" Style="{StaticResource PurpleActionButtonStyle}">
                                            <StackPanel Orientation="Horizontal">
                                                <Image Source="/Assets/Images/report.png" Width="16" Height="16" Margin="0,0,6,0" />
                                                <TextBlock Text="File Actions Report" />
                                            </StackPanel>
                                        </Button>
                                    </WrapPanel>
                                    <WrapPanel Orientation="Horizontal" ItemWidth="178" Margin="0,4,0,4">
                                        <Button ToolTip="Send Results" Style="{StaticResource OrangeActionButtonStyle}">
                                            <StackPanel Orientation="Horizontal">
                                                <Image Source="/Assets/Images/send-email.png" Width="16" Height="16" Margin="0,0,6,0" />
                                                <TextBlock Text="(Re)Send Results" />
                                            </StackPanel>
                                        </Button>
                                    </WrapPanel>
                                    <WrapPanel Orientation="Horizontal" ItemWidth="178" Margin="0,4,0,4">
                                        <Button ToolTip="Positive Papers" Style="{StaticResource BlueActionButtonStyle}">
                                            <StackPanel Orientation="Horizontal">
                                                <Image Source="/Assets/Images/notes.png" Width="16" Height="16" Margin="0,0,6,0" />
                                                <TextBlock Text="Positive Papers" />
                                            </StackPanel>
                                        </Button>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,12">
                            <Border Style="{StaticResource GroupHeadingBorderStyle}">
                                <TextBlock Text="WI Tools" Style="{StaticResource GroupHeadingTextStyle}" />
                            </Border>
                            <Border Style="{StaticResource GroupBodyStyle}">
                                <WrapPanel Orientation="Horizontal" ItemWidth="178" Margin="0,4,0,4">
                                    <Button ToolTip="WI Wizard" Style="{StaticResource GreenActionButtonStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="/Assets/Images/wizard.png" Width="16" Height="16" Margin="0,0,6,0" />
                                            <TextBlock Text="1. WI Wizard" />
                                        </StackPanel>
                                    </Button>
                                    <Button Content="2. Convert to PDF" ToolTip="Convert to PDF" Style="{StaticResource BlueActionButtonStyle}" />
                                    <Button ToolTip="Finalise WI" Style="{StaticResource BlueActionButtonStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="/Assets/Images/copy-red.png" Width="16" Height="16" Margin="0,0,6,0" />
                                            <TextBlock Text="3. Finalise WI" />
                                        </StackPanel>
                                    </Button>
                                    <Button ToolTip="Deliver WI" Style="{StaticResource BlueActionButtonStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="/Assets/Images/email.png" Width="16" Height="16" Margin="0,0,6,0" />
                                            <TextBlock Text="4. Deliver" />
                                        </StackPanel>
                                    </Button>
                                </WrapPanel>
                            </Border>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,12">
                            <Border Style="{StaticResource GroupHeadingBorderStyle}">
                                <TextBlock Text="Update IDs" Style="{StaticResource GroupHeadingTextStyle}" />
                            </Border>
                            <Border Style="{StaticResource GroupBodyStyle}">
                                <WrapPanel Orientation="Horizontal" ItemWidth="178" Margin="0,4,0,4">
                                    <Button ToolTip="Update IDs" Style="{StaticResource PurpleActionButtonStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="/Assets/Images/bar-chart.png" Width="16" Height="16" Margin="0,0,6,0" />
                                            <TextBlock Text="Update IDs" />
                                        </StackPanel>
                                    </Button>
                                </WrapPanel>
                            </Border>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,12">
                            <Border Style="{StaticResource GroupHeadingBorderStyle}">
                                <TextBlock Text="Sections" Style="{StaticResource GroupHeadingTextStyle}" />
                            </Border>
                            <Border Style="{StaticResource GroupBodyStyle}">
                                <WrapPanel Orientation="Horizontal" ItemWidth="178" Margin="0,4,0,4">
                                    <Button ToolTip="Deleted Sections" Style="{StaticResource BlueActionButtonStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="/Assets/Images/recycle-bin.png" Width="16" Height="16" Margin="0,0,6,0" />
                                            <TextBlock Text="Deleted Sections" />
                                        </StackPanel>
                                    </Button>
                                </WrapPanel>
                            </Border>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,12">
                            <Border Style="{StaticResource GroupHeadingBorderStyle}">
                                <TextBlock Text="DELETE File" Style="{StaticResource GroupHeadingTextStyle}" />
                            </Border>
                            <Border Style="{StaticResource GroupBodyStyle}">
                                <WrapPanel Orientation="Horizontal" ItemWidth="178" Margin="0,4,0,4">
                                    <Button ToolTip="Delete File" Style="{StaticResource BlueActionButtonStyle}">
                                        <Image Source="/Assets/Images/x-button.png" Width="16" Height="16" />
                                    </Button>
                                </WrapPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Notes -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Assets/Images/notes.png" Width="16" Height="16" Margin="0,0,6,0" />
                        <TextBlock Text="Notes" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <StackPanel Margin="0,0,0,12">
                            <Border Style="{StaticResource GroupHeadingBorderStyle}">
                                <TextBlock Text="File notes" Style="{StaticResource GroupHeadingTextStyle}" />
                            </Border>
                            <Border Style="{StaticResource GroupBodyStyle}">
                                <StackPanel>
                                    <StackPanel Margin="0,4,0,10">
                                        <TextBlock Text="File Notes" Style="{StaticResource TableLabelStyle}" />
                                        <controls:EntityTable ItemsSource="{Binding NotesTab.FileNotes}" />
                                    </StackPanel>
                                    <WrapPanel Orientation="Horizontal" ItemWidth="178" Margin="0,4,0,4">
                                        <Button ToolTip="Add File Note" Style="{StaticResource WhiteActionButtonStyle}">
                                            <StackPanel Orientation="Horizontal">
                                                <Image Source="/Assets/Images/sticky-notes.png" Width="16" Height="16" Margin="0,0,6,0" />
                                                <TextBlock Text="Add File Note" />
                                            </StackPanel>
                                        </Button>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,12">
                            <Border Style="{StaticResource GroupHeadingBorderStyle}">
                                <TextBlock Text="Quotation notes" Style="{StaticResource GroupHeadingTextStyle}" />
                            </Border>
                            <Border Style="{StaticResource GroupBodyStyle}">
                                <StackPanel Margin="0,4,0,10">
                                    <TextBlock Text="Quotation Notes" Style="{StaticResource TableLabelStyle}" />
                                    <controls:EntityTable ItemsSource="{Binding NotesTab.QuotationNotes}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,12">
                            <Border Style="{StaticResource GroupHeadingBorderStyle}">
                                <TextBlock Text="Collection notes" Style="{StaticResource GroupHeadingTextStyle}" />
                            </Border>
                            <Border Style="{StaticResource GroupBodyStyle}">
                                <StackPanel>
                                    <StackPanel Margin="0,4,0,10">
                                        <TextBlock Text="Collection Notes" Style="{StaticResource TableLabelStyle}" />
                                        <controls:EntityTable ItemsSource="{Binding NotesTab.CollectionNotes}" />
                                    </StackPanel>
                                    <WrapPanel Orientation="Horizontal" ItemWidth="178" Margin="0,4,0,4">
                                        <Button ToolTip="Notes Report" Style="{StaticResource BlueActionButtonStyle}">
                                            <StackPanel Orientation="Horizontal">
                                                <Image Source="/Assets/Images/email.png" Width="16" Height="16" Margin="0,0,6,0" />
                                                <TextBlock Text="Notes Report" />
                                            </StackPanel>
                                        </Button>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <Button Content="Submit" Style="{StaticResource SubmitButtonStyle}" HorizontalAlignment="Left" Margin="0,4,0,12" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Info -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Assets/Images/information.png" Width="16" Height="16" Margin="0,0,6,0" />
                        <TextBlock Text="Info" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <StackPanel Margin="0,0,0,12">
                            <Border Style="{StaticResource GroupBodyStyle}">
                                <StackPanel>
                                    <StackPanel Margin="0,4,0,10">
                                        <TextBlock Text="Info Other" Style="{StaticResource TableLabelStyle}" />
                                        <controls:EntityTable ItemsSource="{Binding InfoTab.InfoOther}" />
                                    </StackPanel>
                                    <WrapPanel Orientation="Horizontal" ItemWidth="304" ItemHeight="76">
                                        <HeaderedContentControl Header="Overall Qualitative Result" Style="{StaticResource FieldStyle}">
                                            <controls:PlaceholderComboBox ItemsSource="{Binding InfoTab.OverallQualitativeResult}" PlaceholderText="Select a Overall Qualitative Result" />
                                        </HeaderedContentControl>
                                        <HeaderedContentControl Header="File Name Prefix" Style="{StaticResource FieldStyle}">
                                            <controls:PlaceholderComboBox ItemsSource="{Binding InfoTab.FileNamePrefix}" PlaceholderText="Select a File Name Prefix" />
                                        </HeaderedContentControl>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <Button Content="Submit" Style="{StaticResource SubmitButtonStyle}" HorizontalAlignment="Left" Margin="0,4,0,12" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Attachments -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Assets/Images/paperclip.png" Width="16" Height="16" Margin="0,0,6,0" />
                        <TextBlock Text="Attachments" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <StackPanel Margin="0,0,0,12">
                            <Border Style="{StaticResource GroupBodyStyle}">
                                <StackPanel>
                                    <StackPanel Margin="0,4,0,10">
                                        <TextBlock Text="Attachments" Style="{StaticResource TableLabelStyle}" />
                                        <controls:EntityTable ItemsSource="{Binding AttachmentsTab.Attachments}" />
                                    </StackPanel>
                                    <WrapPanel Orientation="Horizontal" ItemWidth="178" Margin="0,4,0,4">
                                        <Button ToolTip="Attach" Style="{StaticResource BrownActionButtonStyle}">
                                            <StackPanel Orientation="Horizontal">
                                                <Image Source="/Assets/Images/paperclip.png" Width="16" Height="16" Margin="0,0,6,0" />
                                                <TextBlock Text="Attach" />
                                            </StackPanel>
                                        </Button>
                                        <Button ToolTip="Open" Style="{StaticResource GreenActionButtonStyle}">
                                            <StackPanel Orientation="Horizontal">
                                                <Image Source="/Assets/Images/notes.png" Width="16" Height="16" Margin="0,0,6,0" />
                                                <TextBlock Text="Open" />
                                            </StackPanel>
                                        </Button>
                                        <Button ToolTip="Deliver" Style="{StaticResource OrangeActionButtonStyle}">
                                            <StackPanel Orientation="Horizontal">
                                                <Image Source="/Assets/Images/email.png" Width="16" Height="16" Margin="0,0,6,0" />
                                                <TextBlock Text="Deliver" />
                                            </StackPanel>
                                        </Button>
                                        <Button ToolTip="Popout" Style="{StaticResource PurpleActionButtonStyle}">
                                            <StackPanel Orientation="Horizontal">
                                                <Image Source="/Assets/Images/arrow-up.png" Width="16" Height="16" Margin="0,0,6,0" />
                                                <TextBlock Text="Popout" />
                                            </StackPanel>
                                        </Button>
                                    </WrapPanel>
                                    <StackPanel Margin="0,4,0,10">
