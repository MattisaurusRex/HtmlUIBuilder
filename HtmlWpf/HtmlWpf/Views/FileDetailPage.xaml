                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <Button Content="Submit" Style="{StaticResource SubmitButtonStyle}" HorizontalAlignment="Left" Margin="0,4,0,12" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
