<Page
    x:Class="HtmlWpf.Views.FilesSearchResultPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:HtmlWpf.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="File Search Results">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock Text="File Search Results" Style="{StaticResource PageTitleStyle}" />
            <controls:EntityTable x:Name="ResultsTable" ShowViewButton="True" HorizontalAlignment="Left" />
        </StackPanel>
    </ScrollViewer>
</Page>
