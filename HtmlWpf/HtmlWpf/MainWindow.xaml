<Window
    x:Class="HtmlWpf.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="HtmlWpf"
    Width="1400"
    Height="900">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top navigation: brand, section buttons, version/connection status -->
        <Border Grid.Row="0" Background="{StaticResource NavBarBrush}" Padding="10,5">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Button Content="HtmlUI" Click="Brand_Click" Style="{StaticResource BrandButtonStyle}" />
                    <Button Content="Files" Tag="Files" Click="NavButton_Click" Style="{StaticResource NavButtonStyle}" />
                    <Button Content="Customers" Tag="Customers" Click="NavButton_Click" Style="{StaticResource NavButtonStyle}" />
                    <Button Content="Quotes" Tag="Quotes" Click="NavButton_Click" Style="{StaticResource NavButtonStyle}" />
                    <Button Content="Invoices" Tag="Invoices" Click="NavButton_Click" Style="{StaticResource NavButtonStyle}" />
                </StackPanel>
                <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="Version 1.2" FontSize="10" Foreground="#EAF2FF" TextAlignment="Right" />
                    <TextBlock Text="Connected: Live" FontSize="10" Foreground="#EAF2FF" TextAlignment="Right" />
                </StackPanel>
            </Grid>
        </Border>

        <Frame x:Name="ContentFrame" Grid.Row="1" NavigationUIVisibility="Hidden" Focusable="False" />

        <!-- Footer: copyright/About, current user -->
        <Border Grid.Row="2" Background="{StaticResource NavBarBrush}" Padding="12,2">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#169; 2025 -" Foreground="White" VerticalAlignment="Center" FontSize="12" />
                    <TextBlock VerticalAlignment="Center" FontSize="12" Margin="6,0,0,0">
                        <Hyperlink Click="About_Click" Foreground="White">About</Hyperlink>
                    </TextBlock>
                </StackPanel>
                <TextBlock Text="[User One]" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="White" FontSize="12" />
            </Grid>
        </Border>
    </Grid>
</Window>
